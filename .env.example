# BrightCare OS — Environment Variables
# Copy this file to .env.local for development or set in your deployment platform.

# ── Backend API ──
# URL of the NestJS backend. The /api/proxy route forwards requests here.
API_BASE_URL=http://127.0.0.1:4000

# ── Auth0 (optional — Track B SaaS login, leave blank to use phone+password) ──
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=

# ── App URL ──
# Used for Auth0 redirect_uri and OG metadata resolution.
NEXT_PUBLIC_APP_URL=http://localhost:3000
